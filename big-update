#!/usr/bin/env bash

# ============================================================================
# BIGLINUX UPDATE STACK
# BigLinux / Manjaro / Arch Linux
# Focado em:
#   - BTRFS + Timeshift
#   - Yay (AUR)
#   - Flatpak
# ============================================================================
VERSION="1.0.1"

set -euo pipefail

# ----------------------------------------------------------------------------
# LOG
# ----------------------------------------------------------------------------

LOG="$HOME/bigupdate.log"

# Limpa log antigo a cada execução
: > "$LOG"

# Redireciona stdout/stderr para terminal + log
exec > >(tee -a "$LOG")
exec 2>&1

START_TIME=$(date '+%Y-%m-%d %H:%M:%S')

TOTAL_UPDATES=0

# ----------------------------------------------------------------------------
# CORES
# ----------------------------------------------------------------------------

RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
CYAN='\033[1;36m'
WHITE='\033[1;37m'
RESET='\033[0m'

# ----------------------------------------------------------------------------
# VISUAL
# ----------------------------------------------------------------------------

line() {
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
}

title() {
    clear
    line

    echo -e "${CYAN}"
    echo "  ____  _         _   _           _       _       "
    echo " | __ )(_) __ _  | | | |_ __   __| | __ _| |_ ___ "
    echo " |  _ \| |/ _\` | | | | | '_ \ / _\` |/ _\` | __/ _ \\"
    echo " | |_) | | (_| | | |_| | |_) | (_| | (_| | ||  __/"
    echo " |____/|_|\__, |  \___/| .__/ \__,_|\__,_|\__\___|"
    echo "          |___/        |_|                         "
    echo
    echo "                    BIG UPDATE"
    echo -e "${RESET}"

    line
}

info() {
    echo -e "${CYAN}[INFO]${RESET} $1"
}

ok() {
    echo -e "${GREEN}[OK]${RESET} $1"
}

warn() {
    echo -e "${YELLOW}[AVISO]${RESET} $1"
}

error() {
    echo -e "${RED}[ERRO]${RESET} $1"
}

ask() {
    read -rp "$(echo -e "${YELLOW}[?]${RESET} $1 [s/N]: ")" response
    [[ "$response" =~ ^([sS]|[sS][iI][mM]|[yY])$ ]]
}

# ----------------------------------------------------------------------------
# DEPENDÊNCIAS
# ----------------------------------------------------------------------------

check_requirements() {

    local missing=()

    for cmd in yay flatpak timeshift; do
        if ! command -v "$cmd" &>/dev/null; then
            missing+=("$cmd")
        fi
    done

    if [ ${#missing[@]} -gt 0 ]; then
        error "Dependências ausentes:"
        printf ' - %s\n' "${missing[@]}"
        exit 1
    fi
}

# ----------------------------------------------------------------------------
# VERIFICAÇÃO DE UPDATES
# ----------------------------------------------------------------------------

log_pending_updates() {

    {
        echo
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "PACOTES COM ATUALIZAÇÃO DISPONÍVEL"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo

        echo "[REPOSITÓRIOS OFICIAIS]"
        pacman -Qu 2>/dev/null || true

        echo
        echo "[AUR]"
        yay -Qua 2>/dev/null || true

        echo
    } >> "$LOG"
}

check_updates() {

    info "Sincronizando bancos de dados..."

    if ! sudo pacman -Sy; then

        error "Falha ao sincronizar bancos."

        exit 1
    fi

    echo

    local repo_updates=0
    local aur_updates=0
    local total=0

    repo_updates=$(pacman -Qu 2>/dev/null | wc -l || true)
    aur_updates=$(yay -Qua 2>/dev/null | wc -l || true)

    repo_updates=$(echo "$repo_updates" | tr -d '[:space:]')
    aur_updates=$(echo "$aur_updates" | tr -d '[:space:]')

    total=$((repo_updates + aur_updates))

    TOTAL_UPDATES=$total
    log_pending_updates

    ok "Pacotes oficiais: ${repo_updates}"
    ok "Pacotes AUR:       ${aur_updates}"
    ok "Total updates:     ${total}"
}

# ----------------------------------------------------------------------------
# TIMESHIFT
# ----------------------------------------------------------------------------

check_timeshift_snapshot() {

    info "Verificando snapshot Timeshift do dia..."

    local today
    today=$(date +%Y-%m-%d)

     if sudo timeshift --list | grep "$today" | grep -q "BigUpdateSnapshot"; then

        ok "Snapshot do dia encontrada."

    else

        warn "Nenhuma snapshot encontrada hoje."

        if ask "Deseja criar uma snapshot pré-update agora?"; then

            sudo timeshift \
                --create \
                --scripted \
                --quiet \
                --tags O \
                --comments "BigUpdateSnapshot"

            ok "Snapshot criada com sucesso."

        else
            warn "Atualização continuará sem snapshot recente."
        fi
    fi
}

# ----------------------------------------------------------------------------
# PACOTES ÓRFÃOS
# ----------------------------------------------------------------------------

check_orphans() {

    info "Verificando pacotes órfãos..."

    local orphans

    orphans=$(pacman -Qtdq || true)

    if [ -z "$orphans" ]; then
        ok "Nenhum pacote órfão encontrado."
        return
    fi

    echo
    echo -e "${YELLOW}Pacotes órfãos:${RESET}"
    echo

    pacman -Qdt

    echo

    if ask "Deseja remover os pacotes órfãos?"; then

        sudo pacman -Rns $(pacman -Qtdq)

        ok "Pacotes órfãos removidos."
    fi
}

# ----------------------------------------------------------------------------
# UPDATE SISTEMA
# ----------------------------------------------------------------------------

update_system() {

    info "Atualizando sistema BigLinux..."

    yay -Su \
        --noconfirm \
        --answerclean None \
        --answerdiff None

    ok "Sistema atualizado."
}

# ----------------------------------------------------------------------------
# FLATPAK
# ----------------------------------------------------------------------------

update_flatpaks() {

    info "Atualizando Flatpaks..."

    flatpak update -y

    ok "Flatpaks atualizados."

    echo

    info "Removendo Flatpaks não utilizados..."

    flatpak uninstall --unused -y

    ok "Flatpaks órfãos removidos."
}

# ----------------------------------------------------------------------------
# FINALIZAÇÃO
# ----------------------------------------------------------------------------

finish() {

    local END_TIME
    END_TIME=$(date '+%Y-%m-%d %H:%M:%S')

    line

    echo -e "${GREEN}"
    echo " Atualização concluída com sucesso."
    echo -e "${RESET}"

    line

    echo "Início: ${START_TIME}"
    echo "Fim:    ${END_TIME}"
    echo

    # Notificação apenas se houve updates
    if [[ "$TOTAL_UPDATES" -gt 0 ]]; then

        warn "Reinicialização recomendada após atualizações do sistema."

        echo

        if command -v notify-send &>/dev/null; then

            notify-send \
                "BIG UPDATE" \
                "${TOTAL_UPDATES} atualização(ões) instalada(s).\nReinicialização recomendada."
        fi
    else

        ok "Nenhuma atualização foi necessária."
    fi

    ok "Log salvo em:"
    echo "  ${LOG}"
    echo
}

# ----------------------------------------------------------------------------
# EXECUÇÃO
# ----------------------------------------------------------------------------

# Exibe a versão
if [[ "${1:-}" == "--version" ]]; then
    echo "big-update v${VERSION}"
    exit 0
fi

# Mostra o help do script
if [[ "${1:-}" == "--help" ]]; then
    cat <<EOF

BigUpdate v${VERSION}
Just a script for updating BigLinux based on Manjaro

Uso:
  big-update [opções]

Opções:
  --upmirrors    Atualiza lista de mirrors antes do update
  --version      Mostra versão do programa
  --help         Mostra esta ajuda

EOF
    exit 0
fi

main() {

    title

    check_requirements

    echo
    check_updates

    echo
    check_timeshift_snapshot

    echo
    check_orphans

    echo
    update_system

    echo
    update_flatpaks

    echo
    finish
}

main
